---
import Base from "./Base.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
interface Props { title: string; description: string }
const { title, description } = Astro.props;
const pages = [
  { href: "/docs/getting-started/", label: "Getting started" },
  { href: "/docs/usage/", label: "Usage" },
  { href: "/docs/ci/", label: "CI & GitHub Action" },
  { href: "/docs/config/", label: "Configuration" },
  { href: "/docs/output/", label: "Output formats" },
  { href: "/rules/", label: "Rules reference" },
];
const here = Astro.url.pathname;
---
<Base title={title} description={description}>
  <Nav />
  <div class="container docs">
    <aside>
      <nav>
        {pages.map((p) => (
          <a href={p.href} class={here === p.href ? "active" : ""}>{p.label}</a>
        ))}
      </nav>
    </aside>
    <article class="prose"><slot /></article>
  </div>
  <Footer />
</Base>
<style>
  .docs { display: grid; grid-template-columns: 14rem 1fr; gap: 2.5rem; margin-top: 2rem; align-items: start; }
  aside { position: sticky; top: 4.5rem; }
  aside nav { display: flex; flex-direction: column; gap: 0.4rem; }
  aside a { color: var(--fg-dim); padding: 0.25rem 0; }
  aside a.active { color: var(--accent); }
  .prose { max-width: 46rem; }
  .prose :global(h1) { margin-top: 0; }
  .prose :global(h2) { margin-top: 2rem; font-size: 1.25rem; }
  .prose :global(a) { color: var(--accent); }
  .prose :global(code) { background: var(--bg-elev); border: 1px solid rgba(255, 255, 255, 0.16); padding: 0.04rem 0.35rem; border-radius: 5px; font-size: 0.88em; }
  .prose :global(pre code) { background: none; border: 0; padding: 0; font-size: inherit; }
  .prose :global(table) { width: 100%; border-collapse: collapse; }
  .prose :global(th), .prose :global(td) { border: 1px solid var(--border); padding: 0.4rem 0.6rem; text-align: left; }
  @media (max-width: 760px) { .docs { grid-template-columns: 1fr; } aside { position: static; } }
</style>
