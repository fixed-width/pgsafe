---
const repo = "https://github.com/fixed-width/pgsafe";
---
<footer class="ft">
  <div class="container ft-row">
    <span>pgsafe — static safety linter for PostgreSQL DDL migrations.</span>
    <span>Apache-2.0 · <a href={repo} rel="noopener noreferrer">source</a></span>
  </div>
</footer>
<style>
  .ft { border-top: 1px solid var(--border); margin-top: 4rem; color: var(--fg-dim); font-size: 0.85rem; }
  .ft-row { display: flex; flex-wrap: wrap; gap: 0.5rem 1.5rem; justify-content: space-between; padding-top: 1.5rem; padding-bottom: 2rem; }
</style>
